# InvestAI - Environment Variables (copy to .env and fill in your values)

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=investai
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=investai
POSTGRES_HOST=localhost
POSTGRES_PORT=5435

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=your_redis_password

# ── Binance API (optional – used for real crypto portfolio sync) ─────────────
# Get your keys at https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# ── Groq API (required for AI chat and analysis) ────────────────────────────
# Free tier available at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_USERNAME=your_username
AUTH_PASSWORD=your_password
JWT_SECRET=a_long_random_secret_string_at_least_32_chars

# ── App ──────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8091
